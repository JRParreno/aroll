DATABASE_URL=postgresql://aroll:aroll@localhost:5432/aroll
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- CORS (production) ---
# Comma-separated list of allowed browser origins, e.g. your deployed admin/owner web URLs.
# Example: https://admin.example.com,https://owner.example.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- CORS (development only) ---
# When true, the API also accepts any http(s) origin on localhost or 127.0.0.1 (any port).
# This is convenient for local Vite/Flutter web dev but must be disabled in production:
#   CORS_ALLOW_LOCALHOST_REGEX=false
CORS_ALLOW_LOCALHOST_REGEX=true

# Local directory for registration document uploads (not committed to git).
REGISTRATION_UPLOAD_DIR=uploads/registrations
